{
	"name": "ollama-d",
	"description": "D bindings for the Ollama API",
	"license": "MIT",
	"version": "0.4.0",
	"targetPath": "lib",
	"authors": [
		"Matheus Catarino França"
	],
	"dflags": [
		"-preview=dip1000",
		"-preview=rvaluerefparam"
	],
	"dflags-dmd": ["-verrors=context"],
	"dflags-ldc": ["--verrors-context", "--preview=safer"],
	"subPackages": [
		{
			"name": "simple",
			"targetType": "executable",
			"targetPath": "bin",
			"targetName": "client",
			"sourceFiles": ["samples/simple/app.d"],
			"lflags-windows": ["/LIBPATH:$PACKAGE_DIR\\lib"],
			"lflags-posix": ["-L$PACKAGE_DIR/lib"],
			"libs": ["ollama-d"]
		},
		{
			"name": "coder",
			"targetType": "executable",
			"targetPath": "bin",
			"targetName": "coder",
			"sourceFiles": ["samples/coder/app.d"],
			"lflags-windows": ["/LIBPATH:$PACKAGE_DIR\\lib"],
			"lflags-posix": ["-L$PACKAGE_DIR/lib"],
			"libs": ["ollama-d"]
		},
		{
			"name": "chat",
			"targetType": "executable",
			"targetPath": "bin",
			"targetName": "chat",
			"sourceFiles": ["samples/chat/app.d"],
			"lflags-windows": ["/LIBPATH:$PACKAGE_DIR\\lib"],
			"lflags-posix": ["-L$PACKAGE_DIR/lib"],
			"libs": ["ollama-d"]
		},
		{
			"name": "agent",
			"targetType": "executable",
			"targetPath": "bin",
			"targetName": "agent",
			"sourceFiles": ["samples/agent/app.d"],
			"lflags-windows": ["/LIBPATH:$PACKAGE_DIR\\lib"],
			"lflags-posix": ["-L$PACKAGE_DIR/lib"],
			"libs": ["ollama-d"]
		}
	]
}
